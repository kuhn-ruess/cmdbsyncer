#!/usr/bin/env bash
# Pre-commit hook:
#   1. Run the unit-test suite; abort the commit on failure.
#   2. Refresh buildinfo.txt with the current UTC timestamp and stage it.
# Activate once with:  git config core.hooksPath .githooks
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

DATE=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
echo "BUILD_DATE=$DATE" > application/buildinfo.txt
git add application/buildinfo.txt
echo "Updated application/buildinfo.txt -> $DATE"

PYLINT_BIN=""
if [ -x "$REPO_ROOT/.venv/bin/pylint" ]; then
    PYLINT_BIN="$REPO_ROOT/.venv/bin/pylint"
elif [ -x "$REPO_ROOT/venv/bin/pylint" ]; then
    PYLINT_BIN="$REPO_ROOT/venv/bin/pylint"
elif command -v pylint >/dev/null 2>&1; then
    PYLINT_BIN="$(command -v pylint)"
fi

if [ -n "$PYLINT_BIN" ]; then
    CHANGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')
    if [ -n "$CHANGED_PY" ]; then
        echo "Running pylint on staged Python files..."
        # shellcheck disable=SC2086
        if ! "$PYLINT_BIN" $CHANGED_PY; then
            echo
            echo "Pylint reported issues — commit aborted."
            exit 1
        fi
        echo "Pylint passed."
    fi
else
    echo "pylint not found — skipping lint check."
fi

PYTHON_BIN=""
if [ -x "$REPO_ROOT/.venv/bin/python" ]; then
    PYTHON_BIN="$REPO_ROOT/.venv/bin/python"
elif [ -x "$REPO_ROOT/venv/bin/python" ]; then
    PYTHON_BIN="$REPO_ROOT/venv/bin/python"
elif command -v python3 >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python3)"
elif command -v python >/dev/null 2>&1; then
    PYTHON_BIN="$(command -v python)"
fi

if [ -z "$PYTHON_BIN" ]; then
    echo "No python interpreter found — commit aborted."
    exit 1
fi

echo "Running unit tests before commit..."
PRETEST_LOG="$(mktemp -t cmdbsyncer_pretest.XXXXXX)"
trap 'rm -f "$PRETEST_LOG"' EXIT
if ! "$PYTHON_BIN" run_tests.py > "$PRETEST_LOG" 2>&1; then
    echo
    echo "Unit tests failed — commit aborted."
    echo "Full output:"
    cat "$PRETEST_LOG"
    exit 1
fi
echo "All tests passed."
