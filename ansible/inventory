#!/bin/sh
# Backward-compatible shim: thin proxy to the new
# `cmdbsyncer ansible inventory ansible` CLI command.
# Existing playbook invocations using `-i ansible/inventory` keep working
# unchanged. The modern alternative is `-i ansible/syncer.inventory.yml`
# which routes through the cmdbsyncer-inventory plugin (mode local|http).
# Prefer the pip-installed `cmdbsyncer` on PATH; fall back to the
# source-checkout wrapper next to ansible/ so both install layouts work.
if command -v cmdbsyncer >/dev/null 2>&1; then
    exec cmdbsyncer ansible inventory ansible "$@"
else
    exec "$(dirname "$0")/../cmdbsyncer" ansible inventory ansible "$@"
fi
