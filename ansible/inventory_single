#!/bin/sh
# Backward-compatible shim: per-host inventory wrapper used by older
# integrations that pass --host but expect the full Ansible inventory
# shape. Wraps the new `cmdbsyncer ansible inventory ansible --host`
# call so the surrounding playbooks keep working unchanged.

LIMIT_VALUE=""

while [ "$#" -gt 0 ]; do
case "$1" in
    --host)
        LIMIT_VALUE="$2"
        shift 2
        ;;
    --host=*)
        LIMIT_VALUE="${1#--host=}"
        shift
        ;;
    *)
        shift
        ;;
esac
done

# Tell cmdbsyncer where local_config.py lives: ansible/ sits next to
# local_config.py in both source-checkout and pip-install layouts, so
# the shim's parent directory is always the right config root.
SHIM_DIR="$(cd "$(dirname "$0")" && pwd)"
export CMDBSYNCER_CONFIG_DIR="${CMDBSYNCER_CONFIG_DIR:-$(dirname "$SHIM_DIR")}"
# Prefer the pip-installed `cmdbsyncer` on PATH; fall back to the
# source-checkout wrapper next to ansible/ so both install layouts work.
if command -v cmdbsyncer >/dev/null 2>&1; then
    vars=$(cmdbsyncer ansible inventory ansible --host "$LIMIT_VALUE" 2>/dev/null)
else
    vars=$("$SHIM_DIR/../cmdbsyncer" ansible inventory ansible --host "$LIMIT_VALUE" 2>/dev/null)
fi
if [ -z "$vars" ]; then
    vars="{}"
fi
printf '{"_meta":{"hostvars": {"%s": %s}}, "all": {"hosts": ["%s"]}}\n' "$LIMIT_VALUE" "$vars" "$LIMIT_VALUE"
